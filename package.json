{
  "name": "ffmask-picker",
  "private": true,
  "version": "0.0.1",
  "description": "Browser-based visual tool for creating FFmpeg drawbox filter parameters",
  "license": "MIT",
  "author": "AntaresFeng",
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "keywords": [
    "ffmpeg",
    "drawbox",
    "mask",
    "video",
    "overlay",
    "visual-editor"
  ],
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "vite build && node -e \"require('fs').renameSync('dist/index.html','dist/ffmask-picker.html')\"",
    "preview": "vite preview"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
